import torch
import torch.nn as nn
import torchvision.models as models
from torch.utils.data import Dataset, DataLoader
import time

# [1] 논문 스펙과 동일한 차원의 검증용 가상 데이터셋 생성
class CapstoneValidationDataset(Dataset):
    def __init__(self, num_samples=300):
        self.num_samples = num_samples
        # Vision(시각): ResNet18 입력 규격 (3채널, 224x224)
        self.images = torch.randn(num_samples, 3, 224, 224)
        # Kinematic(운동학): 관절 각도 6자유도, 토크 6자유도
        self.angles = torch.randn(num_samples, 6)
        self.torques = torch.randn(num_samples, 6)
        # Target(목표): 다음 상태의 12차원 행동 공간 (각도+토크)
        self.targets = torch.randn(num_samples, 12)

    def __len__(self):
        return self.num_samples

    def __getitem__(self, idx):
        return self.images[idx], self.angles[idx], self.torques[idx], self.targets[idx]

# [2] SoftGrasp 논문의 다중 모달 융합 네트워크 구조 (원본 오픈소스 아키텍처)
class SoftGraspNet(nn.Module):
    def __init__(self, feature_dim=128):
        super(SoftGraspNet, self).__init__()
        self.vision_encoder = models.resnet18(weights=None)
        self.vision_encoder.fc = nn.Linear(512, feature_dim)

        self.angle_encoder = nn.Sequential(nn.Linear(6, 64), nn.ReLU(), nn.Linear(64, feature_dim))
        self.torque_encoder = nn.Sequential(nn.Linear(6, 64), nn.ReLU(), nn.Linear(64, feature_dim))

        self.attention = nn.MultiheadAttention(embed_dim=feature_dim, num_heads=8, batch_first=True)
        self.action_decoder = nn.Sequential(nn.Linear(feature_dim * 3, 256), nn.ReLU(), nn.Linear(256, 12))

    def forward(self, img, angle, torque):
        f_img = self.vision_encoder(img).unsqueeze(1)
        f_ang = self.angle_encoder(angle).unsqueeze(1)
        f_tor = self.torque_encoder(torque).unsqueeze(1)

        f_combined = torch.cat([f_img, f_ang, f_tor], dim=1)
        attn_output, _ = self.attention(f_combined, f_combined, f_combined)
        return self.action_decoder(attn_output.reshape(img.size(0), -1))

# [3] 모델 훈련 및 검증 실행부
def execute_architecture_validation():
    print("==================================================")
    print("SoftGrasp 모델 아키텍처 검증 및 모방 학습 테스트 시작")
    print("==================================================")
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    print(f"[*] 실행 환경: {device}")

    dataset = CapstoneValidationDataset(num_samples=300)
    dataloader = DataLoader(dataset, batch_size=32, shuffle=True)

    model = SoftGraspNet().to(device)
    huber_loss = nn.HuberLoss()
    optimizer = torch.optim.Adam(model.parameters(), lr=1e-4)
    epochs = 15
    lambda_factor = 0.1 # 토크 손실 가중치 (논문 설정)

    start_time = time.time()
    for epoch in range(1, epochs + 1):
        model.train()
        running_loss = 0.0

        for images, angles, torques, targets in dataloader:
            images, angles, torques, targets = images.to(device), angles.to(device), torques.to(device), targets.to(device)

            optimizer.zero_grad()
            outputs = model(images, angles, torques)

            # 논문의 식 (5), (6), (7) 복합 손실 함수 적용
            loss_A = huber_loss(outputs[:, :6], targets[:, :6])
            loss_T = huber_loss(outputs[:, 6:], targets[:, 6:])
            loss = (1 - lambda_factor) * loss_A + lambda_factor * loss_T
            loss.backward()
            optimizer.step()
            running_loss += loss.item()

        avg_loss = running_loss / len(dataloader)
        print(f"Epoch [{epoch:02d}/{epochs}] - 학습 소요 시간: {(time.time()-start_time):.2f}초 - 종합 Loss: {avg_loss:.6f}")

    print("==================================================")
    print("검증 완료: 오픈소스 아키텍처가 정상적으로 컴파일 및 학습됨을 확인했습니다.")

if __name__ == "__main__":
    execute_architecture_validation()
